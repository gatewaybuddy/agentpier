{
  "info": {
    "name": "AgentPier API Collection",
    "description": "Complete API collection for AgentPier trust scoring and verification platform.\n\nIncludes all endpoints with examples, tests, and environment configurations.\n\n**Setup:**\n1. Import this collection\n2. Import the environment file\n3. Set your API key in the environment\n4. Start testing!\n\n**Environments:**\n- Production: https://api.agentpier.org\n- Sandbox: https://sandbox-api.agentpier.org\n- Development: https://brz91cuha4.execute-api.us-east-1.amazonaws.com/dev",
    "version": "1.0.0",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "{{base_url}}",
      "type": "string"
    },
    {
      "key": "api_key",
      "value": "{{api_key}}",
      "type": "string"
    }
  ],
  "auth": {
    "type": "apikey",
    "apikey": [
      {
        "key": "key",
        "value": "X-API-Key",
        "type": "string"
      },
      {
        "key": "value",
        "value": "{{api_key}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Authentication",
      "description": "Agent registration and authentication endpoints",
      "item": [
        {
          "name": "Request Registration Challenge",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has challenge_id', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('challenge_id');",
                  "    pm.environment.set('challenge_id', jsonData.challenge_id);",
                  "});",
                  "",
                  "pm.test('Challenge expires in 300 seconds', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.expires_in_seconds).to.eql(300);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"test_agent_{{$randomInt}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/challenge",
              "host": ["{{base_url}}"],
              "path": ["auth", "challenge"]
            },
            "description": "Request a registration challenge for a new agent. No authentication required.\n\nRate limit: 30/hour per IP"
          }
        },
        {
          "name": "Register Agent",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has agent_id', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('agent_id');",
                  "    pm.environment.set('test_agent_id', jsonData.agent_id);",
                  "});",
                  "",
                  "pm.test('Response has API key', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('api_key');",
                  "    pm.environment.set('agent_api_key', jsonData.api_key);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"challenge_id\": \"{{challenge_id}}\",\n  \"challenge_response\": \"59\",\n  \"agent_name\": \"Test Agent {{$randomInt}}\",\n  \"agent_description\": \"A test agent for API validation\",\n  \"capabilities\": [\"code_review\", \"documentation\"],\n  \"contact_info\": \"test@example.com\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/register2",
              "host": ["{{base_url}}"],
              "path": ["auth", "register2"]
            },
            "description": "Register a new agent with challenge response. Returns agent_id and API key.\n\nRate limit: 20/hour per IP"
          }
        },
        {
          "name": "Agent Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has session token', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('session_token');",
                  "    pm.environment.set('session_token', jsonData.session_token);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"agent_id\": \"{{test_agent_id}}\",\n  \"api_key\": \"{{agent_api_key}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            },
            "description": "Login with agent credentials to get session token.\n\nRate limit: 20/minute per IP"
          }
        }
      ]
    },
    {
      "name": "Trust Scoring",
      "description": "Trust score queries and management",
      "item": [
        {
          "name": "Get Agent Trust Score",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response has trust_score', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('trust_score');",
                  "    pm.expect(jsonData.trust_score).to.be.a('number');",
                  "    pm.expect(jsonData.trust_score).to.be.within(0, 100);",
                  "});",
                  "",
                  "pm.test('Response has ACE scores', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('ace_scores');",
                  "    pm.expect(jsonData.ace_scores).to.have.property('autonomy');",
                  "    pm.expect(jsonData.ace_scores).to.have.property('competence');",
                  "    pm.expect(jsonData.ace_scores).to.have.property('experience');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trust/agents/{{test_agent_id}}",
              "host": ["{{base_url}}"],
              "path": ["trust", "agents", "{{test_agent_id}}"]
            },
            "description": "Get comprehensive trust score and details for an agent.\n\nIncludes:\n- Overall trust score (0-100)\n- ACE component scores\n- Trust tier classification\n- Transaction statistics\n- Verification status"
          }
        },
        {
          "name": "Get Trust Score (Verified Agent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Agent is verified', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.verification_status).to.eql('verified');",
                  "    pm.expect(jsonData.trust_score).to.be.above(80);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trust/agents/test_agent_verified",
              "host": ["{{base_url}}"],
              "path": ["trust", "agents", "test_agent_verified"]
            },
            "description": "Example query for a pre-verified test agent with high trust score."
          }
        },
        {
          "name": "Submit Trust Signal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Signal accepted', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.status).to.eql('accepted');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"signal_type\": \"transaction_completion\",\n  \"transaction_id\": \"txn_{{$randomUUID}}\",\n  \"rating\": 5,\n  \"outcome\": \"success\",\n  \"metadata\": {\n    \"task_complexity\": \"medium\",\n    \"response_time_minutes\": 15,\n    \"customer_satisfaction\": 4.8,\n    \"task_category\": \"code_review\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/trust/agents/{{test_agent_id}}/signals",
              "host": ["{{base_url}}"],
              "path": ["trust", "agents", "{{test_agent_id}}", "signals"]
            },
            "description": "Submit a trust signal (transaction completion, review, etc.) to update agent's trust score.\n\nSupported signal types:\n- transaction_completion\n- user_feedback\n- marketplace_review\n- verification_event"
          }
        },
        {
          "name": "Get Trust History",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('History contains data points', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('history');",
                  "    pm.expect(jsonData.history).to.be.an('array');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/trust/agents/{{test_agent_id}}/history?days=30",
              "host": ["{{base_url}}"],
              "path": ["trust", "agents", "{{test_agent_id}}", "history"],
              "query": [
                {
                  "key": "days",
                  "value": "30"
                }
              ]
            },
            "description": "Get trust score history and trends for an agent.\n\nQuery parameters:\n- days: Number of days of history (default: 30, max: 365)\n- granularity: daily, weekly, monthly (default: daily)"
          }
        }
      ]
    },
    {
      "name": "V-Token Verification",
      "description": "Agent identity verification using V-Tokens",
      "item": [
        {
          "name": "Issue V-Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('V-Token generated', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData).to.have.property('vtoken');",
                  "    pm.expect(jsonData.vtoken).to.match(/^vt_[a-zA-Z0-9]+$/);",
                  "    pm.environment.set('test_vtoken', jsonData.vtoken);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"expires_in_hours\": 24,\n  \"purpose\": \"marketplace_integration\",\n  \"metadata\": {\n    \"platform\": \"test_marketplace\",\n    \"session_id\": \"sess_{{$randomUUID}}\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/vtokens/issue",
              "host": ["{{base_url}}"],
              "path": ["vtokens", "issue"]
            },
            "description": "Issue a V-Token for agent identity verification.\n\nV-Tokens are cryptographic proofs that an agent is who they claim to be.\nUseful for:\n- Cross-marketplace reputation transfers\n- Secure agent-to-agent communication\n- Identity verification in transactions"
          }
        },
        {
          "name": "Verify V-Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('V-Token is valid', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.valid).to.be.true;",
                  "    pm.expect(jsonData).to.have.property('issuer');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vtokens/{{test_vtoken}}/verify",
              "host": ["{{base_url}}"],
              "path": ["vtokens", "{{test_vtoken}}", "verify"]
            },
            "description": "Verify a V-Token and get agent information.\n\nNo authentication required - this is a public verification endpoint.\n\nReturns:\n- Validity status\n- Issuer agent information\n- Trust score at time of issue\n- Expiration details"
          }
        },
        {
          "name": "Verify V-Token (Test - Verified Agent)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Test token works', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.valid).to.be.true;",
                  "    pm.expect(jsonData.issuer.agent_name).to.include('Test');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/vtokens/vt_test_verified_123/verify",
              "host": ["{{base_url}}"],
              "path": ["vtokens", "vt_test_verified_123", "verify"]
            },
            "description": "Example verification with a pre-generated test V-Token."
          }
        }
      ]
    },
