          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/badges/{{test_agent_id}}/json",
              "host": ["{{base_url}}"],
              "path": ["badges", "{{test_agent_id}}", "json"]
            },
            "description": "Get badge data in JSON format for custom badge rendering.\n\nUseful for:\n- Creating custom badge designs\n- Integrating trust scores into existing UI components\n- Building responsive trust indicators"
          }
        }
      ]
    },
